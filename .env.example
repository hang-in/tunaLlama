# tunaLlama .env 예시 - `.env` 로 복사 후 값 채우기.
# config.toml 의 `api_key_env = "..."` 가 가리키는 환경변수만 의미가 있다.

# Ollama Cloud (config.toml 의 [llm.ollama_cloud].api_key_env 와 일치시킬 것)
# OLLAMA_CLOUD_API_KEY=

# LM Studio (로컬은 보통 무의미)
# LMSTUDIO_API_KEY=

# === 임베딩 / 검색 (Phase 5+) ===

# 벡터 임베딩 모델. dim 1024 호환 모델만 swap 가능.
# 후보: BAAI/bge-m3 (default) / nlpai-lab/KURE-v1 (Korean finetune) / Qwen/Qwen3-Embedding-0.6B
# TUNA_EMBEDDING_MODEL=BAAI/bge-m3

# 임베딩 device. auto / cpu / mps / cuda.
# macOS 일상 사용엔 cpu 권장 (다른 앱 GPU 보호).
# TUNA_EMBEDDING_DEVICE=auto

# === 메모리 layer (Phase 6+) ===

# delegation 후 state.md 자동 추출 hook. 0 으로 설정 시 비활성.
# TUNA_AUTO_EXTRACT_STATE=1

# === Hook (옵션) ===

# pre_tool_use hook 의 큰 파일 임계값 (바이트). default 5000.
# TUNALLAMA_HOOK_THRESHOLD=5000

# === Organic dogfooding metrics (v0.5.7+) ===

# 매 delegation 후 자동 metric 수집. 0 으로 설정 시 비활성.
# TUNA_ORGANIC_METRICS=1

# metrics db path override. default ~/.tunallama/metrics.db.
# TUNA_METRICS_DB=

# === project state.md base path (테스트 / multi-tenant) ===

# default ~/.tunallama/projects. 변경 시 다른 base 사용.
# TUNA_STATE_BASE=
